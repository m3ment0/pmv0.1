      <main class="col-md-9 ms-sm-auto col-lg-10 px-md-2">
        <!--<div
          class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
        </div>-->
        <!--Tabla-->

        <div class="row">

          <!--<div class="col-md-12">-->

          <div class="card">
            <div class="table-wrapper">
              <div class="table-title">
                <div class="row">

                  <div class="col-md-6">
                    <h2>Gestion <b>Pacientes</b></h2>
                  </div>

                  <div class="col-md-6">

                    <a href="/registro-paciente" class="btn btn-primary"><i class="material-icons">&#xE147;</i>
                      <span>Crear Paciente</span></a>

                    <a href="/reporte-paciente" class="btn btn-primary"><i class="material-icons">&#xE24D;</i>
                      <span>Crear
                        Pdf</span></a>
                    <a href="/principal" class="btn btn-primary"><i class="material-icons">&#xE860;</i>
                      <span>Principal</span></a>

                  </div>
                </div>
              </div>
              <!--Busqueda-->
              <div class="row">
                <nav class=" navbar- bg-light">
                  <form action="/buscar-paciente" method="post" class="form-inline">

                    <input class="form-control mr-sm-2 mb-2" name="entradaid" type="number" placeholder="Id" aria-label="Id">
                    <input class="form-control mr-sm-2" name="entrada" type="search" placeholder="Nombres"
                      aria-label="Search">
                    <div class="row-md-12 mt-2">
                      <button class="btn btn-outline-success my-2 my-sm-0" type="submit">Buscar</button>

                    </div>

                  </form>
                </nav>
              </div>

              <table class="table table-striped table-hover">
                <thead>
                  <tr>
                    <th>Id</th>
                    <th>Nombres</th>
                    <th>Num Documento</th>
                    <th>Telefono</th>
                    <th>Correo</th>
                    <th>Acciones</th>
                  </tr>
                </thead>
                <tbody>
                  <!---->
                  <% registro.forEach((user)=>{ %>
                    <tr>
                      <td>
                        <%= user.id_paciente %>
                      </td>
                      <td>
                        <%= user.nombres %>
                      </td>
                      <td>
                        <%= user.num_documento %>
                      </td>
                      <td>
                        <%= user.telefono %>
                      </td>
                      <td>
                        <%= user.correo %>
                      </td>
                      <td>


                        <a href="/cargar-paciente/<%= user.id_paciente %>" class="edit" data-toggle="modal"><i
                            class="material-icons" data-toggle="tooltip" title="" data-original-title="Editar"></i></a>
                        <a href="/eliminar-paciente/<%= user.id_paciente %>" class="delete" title="Eliminar"
                          data-toggle="tooltip"><i class="material-icons">&#xE5C9;</i></a>


                      </td>

                    </tr>

                    <% }) %>


                </tbody>

              </table>



            </div>
          </div>
          <!--</div>Columna-->
